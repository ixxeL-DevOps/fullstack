{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "enabledManagers": ["helmv3", "helm-values", "github-actions", "docker", "custom.regex", "kubernetes"],
  "ignorePaths": [
    "docs/**",
    "**/*.sops.*",
    "**/devbox.*"
  ],
  "helmv3": {
    "fileMatch": ["gitops/manifests/.+\\.ya?ml$", "gitops/bootstrap/.+\\.ya?ml$"]
  },
  "helm-values": {
    "fileMatch": ["gitops/manifests/.+\\.ya?ml$", "gitops/bootstrap/.+\\.ya?ml$"]
  },
  "kubernetes": {
    "fileMatch": ["\\.taskfiles/.+\\.ya?ml$", "gitops/manifests/.+\\.ya?ml$"]
  },
  "custom.regex": {
    "fileMatch": ["gitops/.+\\.ya?ml$", "infra/**"]
  }
}
