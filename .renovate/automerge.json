{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
      {
        "description": "Auto merge patch and minor",
        "matchDatasources": ["docker", "github-releases", "github-tags", "helm"],
        "automerge": true,
        "automergeType": "pr",
        "platformAutomerge": true,
        "matchUpdateTypes": ["minor", "patch"]
      }
    ]
  }